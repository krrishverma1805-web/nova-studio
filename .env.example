# -----------------------------------------------------------------------------
# DATABASE CONFIGURATIONS
# -----------------------------------------------------------------------------
# Primary Database (PostgreSQL) - Used by Prisma
# Schema is included in the URL for sub-tenants/folders
DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/novastudio?schema=public"

# Secondary Database (MongoDB) - Used by Mongoose for Analytics & Contact Logging
MONGODB_URI="mongodb://localhost:27017/novastudio"

# -----------------------------------------------------------------------------
# AUTHENTICATION CONFIGURATIONS (NextAuth v4)
# -----------------------------------------------------------------------------
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-32-character-nextauth-secret-key-goes-here"

# Canonical URL of the application
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# ADMIN LOGIN CREDENTIALS
# -----------------------------------------------------------------------------
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="select-a-strong-password-for-production"
